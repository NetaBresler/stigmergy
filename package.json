{
  "name": "stigmergy",
  "version": "0.0.0",
  "description": "A framework for coordinating LLM agents through a shared medium with decay.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "migrations"],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "STIGMERGY_TEST_PG_URL=$STIGMERGY_TEST_PG_URL vitest run tests/postgres-js.integration.test.ts",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@electric-sql/pglite": "^0.2.17",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NetaBresler/stigmergy.git"
  },
  "keywords": [
    "stigmergy",
    "multi-agent",
    "llm",
    "coordination",
    "pheromone",
    "swarm",
    "agent-framework"
  ]
}
